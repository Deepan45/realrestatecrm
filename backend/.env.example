# Server
PORT=4000
APP_URL=http://localhost:3000
# This server's own public URL (used to build absolute links to uploaded images/
# videos in outbound WhatsApp messages) — set to the real API domain in production
PUBLIC_API_URL=http://localhost:4000

# Database
DATABASE_URL=postgresql://postgres:<password>@<host>:5432/realcrm

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# NOTE: Every value below under WhatsApp/MSG91/SmartPing/OpenAI/Meta/Website
# Sync/Lead Webhooks can also be configured from the app itself — log in as
# Super Admin → Settings → Integrations. Whatever's saved there overrides these
# env vars immediately (no restart needed); these just seed a fresh install.
#
# WhatsApp: "mock" logs messages locally, "cloud" uses WhatsApp Cloud API, "msg91" uses
# MSG91, "smartping" uses SmartPing (smartping.in)
WHATSAPP_PROVIDER=mock
WHATSAPP_CLOUD_API_URL=https://graph.facebook.com/v19.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# MSG91 (used when WHATSAPP_PROVIDER=msg91) — from MSG91 dashboard
MSG91_AUTH_KEY=
MSG91_INTEGRATED_NUMBER=

# SmartPing (used when WHATSAPP_PROVIDER=smartping) — from your SmartPing dashboard.
# CAMPAIGN_NAME must be a Live, Meta-approved WhatsApp template campaign whose single
# variable placeholder is filled with our fully-rendered message text. Submit this
# template for approval first (see the comment above SmartPingProvider in
# backend/src/services/whatsapp.service.ts for the exact text), then create a Live
# campaign in SmartPing pointing at it and put that campaign's name here.
SMARTPING_API_KEY=
SMARTPING_CAMPAIGN_NAME=

# AI Operating Agent — "openai" or "gemini" picks which provider actually serves it
AI_PROVIDER=openai

# OpenAI (used when AI_PROVIDER=openai) — from platform.openai.com
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# USD per 1,000,000 tokens, used only to estimate cost on the AI Usage & Cost screen —
# defaults match gpt-4o-mini's public pricing; update if your plan/model differs.
OPENAI_INPUT_PRICE_PER_MILLION=0.15
OPENAI_OUTPUT_PRICE_PER_MILLION=0.6

# Google Gemini (used when AI_PROVIDER=gemini) — from aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
# USD per 1,000,000 tokens — defaults match gemini-1.5-flash's public pricing; update if
# your plan/model differs.
GEMINI_INPUT_PRICE_PER_MILLION=0.075
GEMINI_OUTPUT_PRICE_PER_MILLION=0.3

# Email (leave SMTP_HOST empty to log emails to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=RealRest CRM <noreply@realrest.example>

# Public site origin — used to build property links shared with partners on WhatsApp
CLIENT_URL=http://localhost:3000

# Bi-directional property sync with the public marketing website.
# Outbound: CRM pushes property changes to WEBSITE_API_URL (Bearer WEBSITE_API_KEY);
# leave empty to log the payloads locally instead of calling out.
# Inbound: the website POSTs to /api/integrations/website/properties with
# X-Webhook-Secret: WEBSITE_WEBHOOK_SECRET; empty = inbound webhook disabled (503).
WEBSITE_API_URL=
WEBSITE_API_KEY=
WEBSITE_WEBHOOK_SECRET=

# Shared secret for generic inbound lead webhooks (website contact forms / CTA
# pop-ups → /api/leads/webhook/website, WhatsApp click-to-chat relays →
# /api/leads/webhook/whatsapp-click). Empty = these webhooks are disabled (503).
LEAD_WEBHOOK_SECRET=

# Meta (Facebook/Instagram) Lead Ads webhook — /api/leads/webhook/meta
# VERIFY_TOKEN: any string, must match the one entered in the Meta App dashboard.
# APP_SECRET: validates the X-Hub-Signature-256 on incoming events.
# PAGE_ACCESS_TOKEN: used to fetch each lead's field data from the Graph API.
META_VERIFY_TOKEN=
META_APP_SECRET=
META_PAGE_ACCESS_TOKEN=
